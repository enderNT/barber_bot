APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-...
LLM_BASE_URL=
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.1

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=
OPENAI_TIMEOUT_SECONDS=

BARBERSHOP_CONFIG_PATH=config/barbershop.json

MEMORY_BACKEND=postgres
CHECKPOINT_BACKEND=postgres
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/barbershop_assistant
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_DIMS=1536

TRACER_ENABLED=false
TRACER_APP_KEY=barbershop-assistant
TRACER_BATCH_SIZE=25
TRACER_FLUSH_INTERVAL_SECONDS=2.0
TRACER_PROJECTORS_ENABLED=true

QDRANT_ENABLED=false
QDRANT_SIMULATE=true
QDRANT_BASE_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=barbershop_knowledge
QDRANT_TIMEOUT_SECONDS=10
QDRANT_TOP_K=5
QDRANT_VECTOR_SIZE=8

CHATWOOT_REPLY_ENABLED=false
CHATWOOT_API_BASE_URL=
CHATWOOT_API_TOKEN=

NGROK_AUTHTOKEN=
NGROK_DOMAIN=
